{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ActionPlan",
  "type": "object",
  "properties": {
    "plan_id": { "type": "string" },
    "user_id": { "type": "string" },
    "score_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "risk_level": { "type": "string" },
    "primary_threat": { "type": "string" },
    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "order": { "type": "integer" },
          "urgency": { "type": "string", "enum": ["NOW", "TODAY", "BEFORE_EVENT", "DURING", "AFTER"] },
          "action": { "type": "string" },
          "detail": { "type": "string" },
          "completed": { "type": "boolean", "default": false }
        }
      }
    },
    "gemini_raw_output": { "type": "string" },
    "language": { "type": "string" },
    "caregiver_notified": { "type": "boolean" }
  }
}
