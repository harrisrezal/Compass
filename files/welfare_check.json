{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WelfareCheck",
  "type": "object",
  "properties": {
    "check_id": { "type": "string" },
    "user_id": { "type": "string" },
    "triggered_at": { "type": "string", "format": "date-time" },
    "trigger_reason": { "type": "string", "enum": ["score_threshold", "manual", "scheduled", "no_response"] },
    "push_sent_at": { "type": ["string", "null"] },
    "push_acknowledged": { "type": "boolean" },
    "sms_sent_at": { "type": ["string", "null"] },
    "sms_response": { "type": ["string", "null"] },
    "call_initiated_at": { "type": ["string", "null"] },
    "call_answered": { "type": "boolean" },
    "call_outcome": { "type": ["string", "null"], "enum": ["safe", "needs_help", "no_answer", "escalated", null] },
    "ai_transcript": { "type": ["string", "null"] },
    "caregiver_alerted": { "type": "boolean" },
    "resolved": { "type": "boolean" }
  }
}
