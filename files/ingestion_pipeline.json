{
  "name": "compass-ingestion-pipeline",
  "version": "1.0",
  "description": "Pulls CAISO, NOAA, CAL FIRE, FEMA data every 15 minutes and writes to BigQuery",
  "trigger": "scheduled",
  "schedule": "*/15 * * * *",
  "nodes": [
    {
      "id": "caiso-fetch",
      "type": "python",
      "label": "Fetch CAISO grid stress",
      "script": "ingestion/caiso_client.py",
      "function": "fetch_grid_stress",
      "outputs": ["grid_data"]
    },
    {
      "id": "noaa-fetch",
      "type": "python",
      "label": "Fetch NOAA weather per ZIP",
      "script": "ingestion/noaa_client.py",
      "function": "fetch_weather_all_zips",
      "config": { "zip_codes": ["93720", "93722", "95969", "90034", "92103"] },
      "outputs": ["weather_data"]
    },
    {
      "id": "calfire-fetch",
      "type": "python",
      "label": "Fetch CAL FIRE alerts + PSPS",
      "script": "ingestion/calfire_client.py",
      "function": "fetch_active_alerts",
      "outputs": ["alert_data"]
    },
    {
      "id": "normalise",
      "type": "python",
      "label": "Normalise all signals to 0-100",
      "script": "scoring/normalise.py",
      "function": "normalise_all",
      "inputs": ["grid_data", "weather_data", "alert_data"],
      "outputs": ["normalised_signals"]
    },
    {
      "id": "score-engine",
      "type": "python",
      "label": "Run composite risk scoring",
      "script": "scoring/composite.py",
      "function": "calculate_all_user_scores",
      "inputs": ["normalised_signals"],
      "outputs": ["risk_scores"]
    },
    {
      "id": "bq-write",
      "type": "python",
      "label": "Write to BigQuery",
      "script": "ingestion/bigquery_writer.py",
      "function": "write_batch",
      "inputs": ["grid_data", "weather_data", "alert_data", "risk_scores"]
    },
    {
      "id": "alert-check",
      "type": "python",
      "label": "Check alert thresholds",
      "script": "scoring/composite.py",
      "function": "check_and_trigger_alerts",
      "inputs": ["risk_scores"],
      "config": {
        "alert_threshold": 60,
        "escalation_threshold": 80,
        "critical_threshold": 95
      }
    }
  ],
  "edges": [
    { "from": "caiso-fetch", "to": "normalise" },
    { "from": "noaa-fetch", "to": "normalise" },
    { "from": "calfire-fetch", "to": "normalise" },
    { "from": "normalise", "to": "score-engine" },
    { "from": "score-engine", "to": "bq-write" },
    { "from": "score-engine", "to": "alert-check" },
    { "from": "caiso-fetch", "to": "bq-write" },
    { "from": "noaa-fetch", "to": "bq-write" },
    { "from": "alert-data", "to": "bq-write" }
  ]
}
